# =============================================================================
# BookBee AI Recommendation Service — Environment Variables
# =============================================================================
# Sao chép file này thành .env và điền giá trị thực.
# KHÔNG commit file .env lên Git.

# URL của Node.js Backend (không có dấu / ở cuối)
NODE_API_URL=http://localhost:3000

# API Key để xác thực với Node.js data endpoints
# Phải khớp với AI_SERVICE_API_KEY trong backend/.env
AI_SERVICE_API_KEY=bookbee-ai-secret-key-2024

# Cổng FastAPI sẽ chạy (mặc định 8000)
AI_SERVICE_PORT=8000

# Môi trường: development | production
ENVIRONMENT=development
